USER_MEDIDORES=user1
IP_TGJ1=
IP_TGJ2=
IP_GEC32=
IP_GEC3_1=
IP_GEC3_2=
PSW_TGJ1=
PSW_TGJ2=
PSW_GEC32=
PSW_GEC3_1=
PSW_GEC3_2=

METER_OP_PATH=/Operation.html
METER_TIMEOUT_S=4

# ── Microsoft Fabric (escritura a Lakehouse Delta) ─────────────────────────────
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
FABRIC_WORKSPACE_ID=<your-workspace-guid>
# Acepta el displayName del Lakehouse o su GUID. Si el tenant tiene
# FriendlyNameSupportDisabled, hay que usar el GUID (lo confirmás con probe_workspace.py).
FABRIC_LAKEHOUSE_NAME=<your-lakehouse-guid-or-displayname>
# Dejar vacío si el Lakehouse NO tiene schemas habilitados (se descubre con probe_fabric.py).
FABRIC_LAKEHOUSE_SCHEMA=dbo
FABRIC_TABLE_NAME=<your-table-name>
FABRIC_SQL_ENDPOINT_ID=<your-sql-endpoint-guid>     # vacío para saltar refresh manual

# ── Loop / scheduling ─────────────────────────────────────────────────────────
POLL_INTERVAL_S=15
BUFFER_SIZE=3

# ── VACUUM / refresh ──────────────────────────────────────────────────────────
VACUUM_INTERVAL_S=10800     # 3 h
VACUUM_RETAIN_HOURS=0
REFRESH_INTERVAL_S=60

# ── Logs / heartbeat ──────────────────────────────────────────────────────────
# En Linux/systemd: /var/run/fabric-meter-sink/heartbeat
# En Windows/dev: dejar vacío para usar el default relativo (./var/heartbeat)
HEARTBEAT_PATH=
LOG_DIR=
LOG_LEVEL=INFO

# ── Failure escalation ────────────────────────────────────────────────────────
MAX_CONSECUTIVE_WRITE_FAILURES=5
SHUTDOWN_TIMEOUT_S=30
