# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno. Copiar a un .env REAL (este archivo no se lee).
#
# ¿Dónde va el .env real? Depende de CÓMO arranques el server:
#   - LOCAL (npm): server/package.json corre `node --env-file=../.env`. El `../` es
#     relativo a server/, así que lee el .env en la RAÍZ del repo → dashboard-gen-gec3/.env
#   - SERVIDOR (systemd): deploy/dashboard-ws.service usa
#     `EnvironmentFile=/var/www/dashboard-gen/server/.env` y corre `node server.js`
#     directo (sin --env-file) → el .env vive en server/.env
#   deploy/setup.sh hace `cp .env.example server/.env` al provisionar.
# Ambos .env están gitignored. Multi-instancia: lo único distinto entre servidores son
# los valores DB_* (ver docs/deployment-multi-instancia.md); el resto se comparte.
# ─────────────────────────────────────────────────────────────────────────────

# ── Fallback PME (DESHABILITADO por default desde D-120) ─────────────────────
# =1 reactiva el PMEScraper (Playwright/Chromium con login) como fallback hot-standby.
# Vacío/ausente = apagado: cero navegador, extracción solo con los medidores (Modbus).
PME_ENABLED=
# Credenciales del PME — solo aplican con PME_ENABLED=1 (PME_PASSWORD pasa a ser obligatoria).
PME_USER=
PME_PASSWORD=
PME_LOGIN_URL=https://gpme.gecelca.com.co/web
PME_DIAGRAM_URL=
# Server
WS_PORT=3001
# Sub-path de despliegue (reverse proxy compartido con Bitácora). Lo lee update.sh/setup.sh en
# tiempo de BUILD del frontend (Vite base). El backend lo ignora. Servidor UNIFICADO gecelca3
# (convive con Bitácora): APP_BASE_PATH=/dashboard. Despliegue en la raíz (incl. Guajira): dejar
# vacío. Debe empezar con '/' y sin barra final. Ver docs/deployment-multi-instancia.md y
# ../docs/deployment-unificado.md.
APP_BASE_PATH=
# Modo del navegador del PMEScraper — solo aplica con PME_ENABLED=1.
# new = headless moderno (recomendado para servidor, no necesita xvfb)
# false = ventana visible (para debug local)
# true = headless viejo (puede fallar con login PME)
HEADLESS=new

# MSSQL Database
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Microsoft Graph API - Despacho Final emails
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Buzón compartido con los correos de redespacho de GECELCA (GEC3/GEC32).
GRAPH_MAILBOX=
# Buzón compartido con los correos de redespacho de las GUAJIRAS (TGJ1/TGJ2).
# Si queda vacío, el despacho final por email de las Guajiras no corre (cae al fallback XM).
GRAPH_MAILBOXTEG=

# Usuario único (HTTP Basic) compartido por todos los medidores ION8650.
USER_MEDIDORES=user1
# Fallbacks opcionales: si USER_MEDIDORES no está, se usa METER_BASIC_USER; y si un
# PSW_<ID> puntual no está, se usa METER_BASIC_PASS como password por defecto.
METER_BASIC_USER=
METER_BASIC_PASS=

# IPs de cada medidor (red corporativa interna)
IP_TGJ1=
IP_TGJ2=
IP_GEC32=
IP_GEC3_1=
IP_GEC3_2=
# Passwords por medidor
PSW_TGJ1=
PSW_TGJ2=
PSW_GEC32=
PSW_GEC3_1=
PSW_GEC3_2=

# Tuneo opcional del extractor
# Ruta HTTP del medidor de la que se parsea el kW total (default /Operation.html).
METER_OP_PATH=/Operation.html
# Intervalo de polling de cada medidor en ms (default 2000).
METER_POLL_MS=2000
METER_TIMEOUT_MS=6000
# Carry-forward del último valor bueno del medidor durante nulls transitorios (D-116).
# Mientras el TTL no expire, la unidad sigue en 'meter' emitiendo el último MW bueno
# (holding); tras METER_HOLD_TTL_MIN min sin lectura válida emite null (o cede a PME
# si PME_ENABLED=1). Default 3.
METER_HOLD_TTL_MIN=3

# ── Protocolo de extracción primaria (D-118; default modbus desde D-120) ─────
# 'modbus' (default): lee Modbus TCP FC03 (validado en sombra: 0% null vs HTTP, ~50×
# más rápido). 'http' (legacy): raspa /Operation.html — queda solo como rollback
# instantáneo (METER_PROTOCOL=http + restart). Los parámetros Modbus salen del bloque
# METER_MODBUS_* de abajo (los defaults ya son el combo validado).
METER_PROTOCOL=modbus

# ── Modbus TCP (parámetros del lector; D-118) ────────────────────────────────
# Usados por METER_PROTOCOL=modbus en producción y por los scripts de diagnóstico/sombra:
#   npm run probe:modbus   → descubre el combo que iguala el valor HTTP por medidor
#   npm run shadow:modbus  → corre 3h leyendo HTTP y Modbus en paralelo (no toca prod)
#   npm run shadow:analyze → reporte comparativo + veredicto vs criterios
# Reusa IP_<ID>/PSW_<ID>/USER_MEDIDORES (Modbus no usa auth, solo el host). Los defaults
# ya son el combo validado en sombra; solo tocar si probe:modbus imprime otro MATCH.
METER_MODBUS_PORT=502
METER_MODBUS_UNIT_ID=1
# 40204 (INT32, /1000, 3 decimales) es el match probable del kW total HTTP; 40033 es /10.
METER_MODBUS_REGISTER=40204
# Orden de palabras del INT32: high = high-order register first (doc Schneider) | low.
METER_MODBUS_WORD_ORDER=high
# Decode del par de registros: int32 (signed, negativos de Gecelca nativos) | float32.
METER_MODBUS_DECODE=int32
# Divisor de escala: 1000 para 40204, 10 para 40033, 1 para float32.
METER_MODBUS_SCALE=1000
# Override opcional de unitId por medidor: MB_UNIT_<IPKEY>, ej. MB_UNIT_IP_GEC3_1=100.
# Timeout (ms) del probe Modbus y lista de unitIds a sondear (default 1,100,255,0).
PROBE_MODBUS_TIMEOUT_MS=
PROBE_MODBUS_UNIT_IDS=
# Duración del shadow watcher en minutos (default 180 = 3h).
SHADOW_DURATION_MIN=180

# ── W2 Observabilidad + alerting ─────────────────────────────────────────────
# Destino del webhook. Si vacío, alerter sigue evaluando pero no manda webhook.
ALERT_WEBHOOK_URL=
# Formato del cuerpo: teams | slack | generic (default generic).
ALERT_TARGET=generic
# Intervalo de evaluación del alerter en segundos (default 30).
ALERT_POLL_INTERVAL_SEC=30
# Cooldown por incident_key en minutos (default 30).
ALERT_COOLDOWN_MIN=30

# Umbrales (defaults documentados en docs/runbooks/observability.md):
# ≈3 min a 2s/tick; no-op en prod (meterPoller encapsulado), defensivo (D-116).
ALERT_THRESH_METER_CONSEC_ERRORS=90
# Medidor caído ≥ N min (carry-forward agotado) — alerta canónica per-unit (D-116).
ALERT_THRESH_METER_DOWN_MIN=3
ALERT_THRESH_PME_PERSIST_MIN=10
ALERT_THRESH_PME_GLOBAL_MIN=2
ALERT_THRESH_EMAIL_STALE_MIN=20
ALERT_THRESH_REDESP_STALE_MIN=30
ALERT_THRESH_DESPACHO_STALE_MIN=60
ALERT_DESPACHO_AFTER_HOUR_BOG=15
ALERT_THRESH_ACCUMULATOR_STALE_MIN=5

# ── Deviation tracer (diagnóstico de valles en chart de Desviación %) ────────
# Vacío = off (default, zero overhead). Para activar: CSV de unit IDs, ej.
# TRACE_DEVIATION=GEC32  o  TRACE_DEVIATION=GEC32,GEC3.
# Append JSONL en server/traces/trace-<unit>-YYYY-MM-DD-HH.jsonl. Analizar con
# `node server/traces/analyze.js <archivo>`.
TRACE_DEVIATION=

# ── Herramientas / desarrollo ────────────────────────────────────────────────
# =1 salta la validación fail-fast de variables de medidores/PME al cargar config.js.
# Solo para tests o scripts ad-hoc que importan la lista de unidades sin credenciales.
CONFIG_SKIP_VALIDATION=
# Timeout (ms) del script de diagnóstico de medidores (server/scripts/probe-meters.js).
PROBE_TIMEOUT_MS=
# =1 activa el diagnóstico del scraper PME (vuelca screenshot + DOM del diagrama a la carpeta
# temporal del SO para depurar la extracción). Default vacío/OFF: en prod el scraper no escribe
# artefactos de debug y va directo a observar. Solo aplica con PME_ENABLED=1.
PME_DIAGNOSE=