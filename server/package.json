{
  "name": "modashboard-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node --env-file=../.env server.js",
    "dev": "node --env-file=../.env --watch server.js",
    "probe": "node --env-file=../.env scripts/probe-meters.js",
    "smoke": "node --env-file=../.env scripts/smoke-poller.js",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "mssql": "^11.0.1",
    "playwright": "^1.50.0",
    "undici": "^6.19.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
